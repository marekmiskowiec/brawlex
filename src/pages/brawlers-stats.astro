---
import MainNav from "../components/MainNav.astro";
import { brawlerOrder, slugifyBrawler } from "../data/brawlers";
import brawlerStatsData from "../data/brawlers-stats.json";

const title = "Brawlex | Brawler Stats";
const brawlerAssetModules = import.meta.glob("../assets/brawlers/*.avif", {
  eager: true,
  import: "default"
});

type AssetModule = {
  src: string;
};

type StatsRow = {
  name: string;
  hp: number;
  damage: string;
  speed: string;
  range: string;
};

const orderedAssets = Object.entries(brawlerAssetModules)
  .sort(([left], [right]) => {
    const leftId = Number(left.match(/(\d+)\.avif$/)?.[1] ?? 0);
    const rightId = Number(right.match(/(\d+)\.avif$/)?.[1] ?? 0);
    return leftId - rightId;
  })
  .map(([, asset]) => (asset as AssetModule).src);

const portraitByName = new Map(brawlerOrder.map((name, index) => [name, orderedAssets[index] ?? null]));
const statsRows = (brawlerStatsData as StatsRow[])
  .map((entry) => ({
    ...entry,
    portrait: portraitByName.get(entry.name) ?? null,
    href: `/brawlers/${slugifyBrawler(entry.name)}`
  }))
  .sort((left, right) => left.name.localeCompare(right.name));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #090b11;
        --panel: #11141b;
        --panel-strong: #0f131b;
        --text: #e6edf7;
        --muted: #7e8797;
        --line: rgba(255, 255, 255, 0.06);
        --line-strong: rgba(245, 158, 11, 0.16);
        --accent: #f59e0b;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Trebuchet MS", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(245, 158, 11, 0.08), transparent 26%),
          linear-gradient(180deg, #090b11, #0a0d13 55%, #090b11);
      }

      .page-shell { min-height: 100vh; padding: 1rem 1rem 2.5rem; }
      header { padding-top: 0.5rem; }
      main { width: min(1180px, calc(100vw - 2rem)); margin: 1.25rem auto 0; }

      .hero {
        margin-bottom: 1.4rem;
        padding: 1.2rem 1.3rem;
        border: 1px solid var(--line-strong);
        border-radius: 20px;
        background:
          radial-gradient(circle at right, rgba(245, 158, 11, 0.12), transparent 35%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(1.8rem, 3vw, 2.7rem);
        letter-spacing: -0.04em;
      }

      .hero p {
        margin: 0.45rem 0 0;
        color: var(--muted);
        font-size: 0.98rem;
      }

      .stats-shell {
        border: 1px solid var(--line);
        border-radius: 22px;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(17, 20, 27, 0.94), rgba(11, 14, 20, 0.98));
        box-shadow: 0 24px 56px rgba(0, 0, 0, 0.26);
      }

      .stats-table-wrap {
        overflow-x: auto;
      }

      .stats-table {
        width: 100%;
        min-width: 760px;
        border-collapse: collapse;
      }

      .stats-table thead {
        background: rgba(255, 255, 255, 0.02);
      }

      .stats-table th,
      .stats-table td {
        padding: 0.92rem 0.95rem;
        border-top: 1px solid var(--line);
        text-align: left;
      }

      .stats-table thead th {
        border-top: 0;
        color: var(--muted);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 800;
      }

      .stats-table tbody tr {
        transition: background-color 140ms ease;
      }

      .stats-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.02);
      }

      .stats-table td {
        color: #dce4f2;
        font-size: 0.95rem;
      }

      .stats-name {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        color: inherit;
        text-decoration: none;
        font-weight: 700;
      }

      .stats-avatar {
        width: 44px;
        height: 44px;
        flex: 0 0 auto;
        overflow: hidden;
        border-radius: 11px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #0d1119;
      }

      .stats-avatar img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .stats-meta {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.15rem;
        border-bottom: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.015);
      }

      .stats-meta-title {
        margin: 0;
        font-size: 1rem;
      }

      .stats-meta-copy {
        margin: 0.2rem 0 0;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .stats-count {
        flex: 0 0 auto;
        padding: 0.45rem 0.75rem;
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        color: #f7c66c;
        font-size: 0.86rem;
        font-weight: 800;
      }

      @media (max-width: 720px) {
        .page-shell { padding-inline: 0.75rem; }
        main { width: calc(100vw - 1.5rem); }
        .hero { padding: 1rem 1rem 1.05rem; }
        .stats-meta {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header>
        <MainNav currentPath="/brawlers-stats" />
      </header>

      <main>
        <section class="hero">
          <h1>Brawler Stats</h1>
          <p>Live-ready stat table backed by <code>src/data/brawlers-stats.json</code> for health, damage, speed, and range.</p>
        </section>

        <section class="stats-shell" aria-label="Brawler statistics">
          <div class="stats-meta">
            <div>
              <h2 class="stats-meta-title">All Brawlers</h2>
              <p class="stats-meta-copy">Each row links to the matching brawler detail page.</p>
            </div>
            <div class="stats-count">{statsRows.length} entries</div>
          </div>

          <div class="stats-table-wrap">
            <table class="stats-table">
              <thead>
                <tr>
                  <th>Brawler</th>
                  <th>HP</th>
                  <th>Damage</th>
                  <th>Speed</th>
                  <th>Range</th>
                </tr>
              </thead>
              <tbody>
                {statsRows.map((row) => (
                  <tr>
                    <td>
                      <a class="stats-name" href={row.href}>
                        <span class="stats-avatar">
                          {row.portrait ? <img src={row.portrait} alt={`${row.name} avatar`} loading="lazy" /> : null}
                        </span>
                        <span>{row.name}</span>
                      </a>
                    </td>
                    <td>{row.hp}</td>
                    <td>{row.damage}</td>
                    <td>{row.speed}</td>
                    <td>{row.range}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
