---
import MainNav from "../components/MainNav.astro";
import { brawlerGroups, brawlerOrder, slugifyBrawler } from "../data/brawlers";

const title = "Brawlex | Brawlers";
const brawlerAssetModules = import.meta.glob("../assets/brawlers/*.avif", {
  eager: true,
  import: "default"
});

type AssetModule = {
  src: string;
};

const toneStyles = {
  starting: {
    dot: "#b7e3ff",
    accent: "#9fd6ff",
    frame: "linear-gradient(180deg, rgba(183, 227, 255, 0.35), rgba(15, 23, 42, 0.82))"
  },
  rare: {
    dot: "#6dff58",
    accent: "#6dff58",
    frame: "linear-gradient(180deg, rgba(109, 255, 88, 0.3), rgba(15, 23, 42, 0.82))"
  },
  "super-rare": {
    dot: "#5eb7ff",
    accent: "#5eb7ff",
    frame: "linear-gradient(180deg, rgba(94, 183, 255, 0.3), rgba(15, 23, 42, 0.82))"
  },
  epic: {
    dot: "#df53ff",
    accent: "#df53ff",
    frame: "linear-gradient(180deg, rgba(223, 83, 255, 0.3), rgba(15, 23, 42, 0.82))"
  },
  mythic: {
    dot: "#ff5d7d",
    accent: "#ff5d7d",
    frame: "linear-gradient(180deg, rgba(255, 93, 125, 0.28), rgba(15, 23, 42, 0.82))"
  },
  legendary: {
    dot: "#ffcf46",
    accent: "#ffcf46",
    frame: "linear-gradient(180deg, rgba(255, 207, 70, 0.28), rgba(15, 23, 42, 0.82))"
  },
  ultra: {
    dot: "#ff8d43",
    accent: "#ff8d43",
    frame: "linear-gradient(180deg, rgba(255, 141, 67, 0.28), rgba(15, 23, 42, 0.82))"
  }
};

const orderedAssets = Object.entries(brawlerAssetModules)
  .sort(([left], [right]) => {
    const leftId = Number(left.match(/(\d+)\.avif$/)?.[1] ?? 0);
    const rightId = Number(right.match(/(\d+)\.avif$/)?.[1] ?? 0);
    return leftId - rightId;
  })
  .map(([, asset]) => (asset as AssetModule).src);

function getInitials(name: string) {
  return name
    .replace(/&/g, " ")
    .split(/[\s.-]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0])
    .join("")
    .toUpperCase();
}

const portraitByName = new Map(brawlerOrder.map((name, index) => [name, orderedAssets[index] ?? null]));

const groups = brawlerGroups.map((group) => ({
  ...group,
  style: toneStyles[group.tone],
  cards: group.brawlers.map((name) => ({
    name,
    portrait: portraitByName.get(name) ?? null,
    initials: getInitials(name),
    href: `/brawlers/${slugifyBrawler(name)}`
  }))
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Lilita+One&display=swap");

      :root {
        color-scheme: dark;
        --bg: #090b11;
        --panel: #11141b;
        --tile: #151820;
        --text: #e6edf7;
        --muted: #7e8797;
        --line: rgba(255, 255, 255, 0.06);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Lilita One", "Trebuchet MS", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(59, 130, 246, 0.08), transparent 28%),
          linear-gradient(180deg, #090b11, #0a0d13 55%, #090b11);
      }

      .page-shell { min-height: 100vh; padding: 1rem 1rem 2.5rem; }
      header { padding-top: 0.5rem; }
      main { width: min(1180px, calc(100vw - 2rem)); margin: 1.25rem auto 0; }
      .intro {
        margin-bottom: 1.75rem;
        padding: 1.15rem 1.25rem;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
      }
      .intro h1 { margin: 0; font-size: clamp(1.8rem, 3vw, 2.6rem); }
      .intro p { margin: 0.4rem 0 0; color: var(--muted); font-size: 0.98rem; }
      .section { margin-top: 1.8rem; }
      .section-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.95rem; }
      .dot { width: 0.95rem; height: 0.95rem; flex: 0 0 auto; border-radius: 50%; box-shadow: 0 0 18px currentColor; }
      .section-title { margin: 0; font-size: clamp(1.35rem, 2vw, 1.9rem); font-weight: 800; letter-spacing: -0.03em; }
      .count { color: var(--muted); font-size: 1rem; }
      .brawler-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(78px, 78px)); gap: 12px; }
      .tile {
        width: 78px;
        display: block;
        border-radius: 10px;
        color: inherit;
        text-decoration: none;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
        box-shadow: inset 0 0 0 1px var(--line);
        overflow: hidden;
        transition: transform 160ms ease, box-shadow 160ms ease;
      }
      .tile:hover {
        transform: translateY(-2px);
        box-shadow: inset 0 0 0 1px var(--line), 0 12px 24px rgba(0, 0, 0, 0.22);
      }
      .portrait {
        position: relative;
        aspect-ratio: 1 / 1;
        display: grid;
        place-items: center;
        overflow: hidden;
        background: radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.12), transparent 35%), var(--frame);
      }
      .portrait::after {
        content: "";
        position: absolute;
        inset: 8px;
        border-radius: 10px;
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.04), rgba(2, 6, 23, 0.2));
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
        pointer-events: none;
      }
      .portrait img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .initials {
        position: relative;
        z-index: 1;
        font-size: 1.35rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        color: #ffffff;
        text-shadow: 0 3px 10px rgba(0, 0, 0, 0.35);
      }
      .name {
        min-height: 28px;
        display: grid;
        place-items: center;
        padding: 0.38rem 0.3rem 0.45rem;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        border-bottom: 2px solid var(--accent);
        background: var(--tile);
        color: #d8deea;
        text-align: center;
        font-size: 0.68rem;
        font-weight: 800;
        line-height: 1.1;
        text-transform: uppercase;
      }

      @media (max-width: 720px) {
        .page-shell { padding-inline: 0.75rem; }
        main { width: calc(100vw - 1.5rem); }
        .brawler-grid { grid-template-columns: repeat(auto-fill, minmax(72px, 72px)); gap: 10px; }
        .tile { width: 72px; }
        .section-title { font-size: 1.2rem; }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header>
        <MainNav currentPath="/brawlers" />
      </header>

      <main>
        <section class="intro">
          <h1>Brawlers</h1>
          <p>Every brawler now links to its own detail page using the shared Shelly-style layout.</p>
        </section>

        {groups.map((group) => (
          <section class="section" aria-label={group.rarity}>
            <div class="section-header" style={`color: ${group.style.accent};`}>
              <span class="dot" style={`background: ${group.style.dot}; color: ${group.style.dot};`}></span>
              <h2 class="section-title">{group.rarity}</h2>
              <span class="count">({group.brawlers.length})</span>
            </div>

            <div class="brawler-grid">
              {group.cards.map((brawler) => (
                <a class="tile" href={brawler.href} style={`--accent: ${group.style.accent}; --frame: ${group.style.frame};`}>
                  <div class="portrait">
                    {brawler.portrait ? (
                      <img src={brawler.portrait} alt={`${brawler.name} avatar`} loading="lazy" />
                    ) : (
                      <span class="initials">{brawler.initials}</span>
                    )}
                  </div>
                  <div class="name">{brawler.name}</div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </main>
    </div>
  </body>
</html>
