const initialBoard = tiers.map((tier) => ({
  label: tier.label,
  color: tier.color,
  cards: tier.brawlers.map((name) => ({
    name,
    href: `/brawlers/${slugifyBrawler(name)}`,
    portrait: portraitByName.get(name) ?? "",
    scale: portraitScaleByName[name] ?? 1
  }))
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #171b25;
        --panel: #23293a;
        --line: rgba(0, 0, 0, 0.28);
        --text: #f2f5fb;
        --muted: #b8c0d0;
        --hover: rgba(255, 255, 255, 0.06);
        --drop: rgba(255, 255, 255, 0.14);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Trebuchet MS", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(245, 158, 11, 0.06), transparent 24%),
          linear-gradient(180deg, #171b25, #1d2330 55%, #171b25);
      }

      .page-shell { min-height: 100vh; padding: 1rem 1rem 2.5rem; }
      header { padding-top: 0.5rem; }
      main { width: min(1240px, calc(100vw - 2rem)); margin: 1.25rem auto 0; }

      .intro {
        margin-bottom: 1.25rem;
        padding: 1rem 1.2rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.02);
      }

      .intro h1 {
        margin: 0;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
      }

      .intro p {
        margin: 0.35rem 0 0;
        color: var(--muted);
        max-width: 64ch;
      }

      .button {
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        background: rgba(29, 35, 48, 0.96);
        color: var(--text);
        padding: 0.78rem 0.95rem;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .button:hover {
        background: rgba(46, 55, 73, 0.98);
      }

      .button:disabled {
        opacity: 0.6;
        cursor: wait;
      }

      .board {
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.3);
        border-radius: 18px;
        background: var(--panel);
        box-shadow: 0 26px 70px rgba(0, 0, 0, 0.25);
      }

      .tier-row {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        border-top: 1px solid var(--line);
      }

      .tier-row:first-child {
        border-top: 0;
      }

      .tier-label {
        display: grid;
        place-items: center;
        font-size: 2rem;
        font-weight: 900;
        color: #1f2433;
      }

      .tier-content {
        padding: 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        min-height: 98px;
      }

      .tier-content.is-over {
        background: rgba(255, 255, 255, 0.02);
      }

      .card {
        width: 62px;
        color: inherit;
        text-decoration: none;
        cursor: grab;
        border-radius: 8px;
        transition: transform 140ms ease, opacity 140ms ease, background-color 140ms ease;
      }

      .card.is-dragging {
        opacity: 0.35;
      }

      .card.is-hidden {
        display: none;
      }

      .card.is-target {
        background: var(--drop);
      }

      .card:hover .thumb {
        transform: translateY(-2px);
      }

      .thumb {
        border: 3px solid #05070c;
        background: #0d1119;
        overflow: hidden;
        transition: transform 140ms ease;
      }

      .thumb img {
        width: 100%;
        display: block;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        transform: scale(var(--portrait-scale, 1));
        transform-origin: center;
      }

      .name {
        margin-top: 4px;
        color: #f4f7ff;
        font-size: 0.74rem;
        font-weight: 700;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .card-placeholder {
        width: 62px;
        min-height: 82px;
        border: 2px dashed rgba(255, 255, 255, 0.22);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
      }

      @media (max-width: 720px) {
        .page-shell { padding-inline: 0.75rem; }
        main { width: calc(100vw - 1.5rem); }
        .intro {
          flex-direction: column;
        }
        .button {
          width: 100%;
        }
        .tier-row { grid-template-columns: 58px minmax(0, 1fr); }
        .tier-label { font-size: 1.5rem; }
        .tier-content { gap: 8px; padding: 10px; }
        .card { width: 56px; }
        .card-placeholder { width: 56px; min-height: 74px; }
        .name { font-size: 0.68rem; }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header>
        <MainNav currentPath="/meta-builder" />
      </header>

      <main>
        <section class="intro">
          <div>
            <h1>Meta Builder</h1>
            <p>Drag a brawler onto another brawler to reorder within a tier, or drag it into another tier to move it there. The leftmost card is the strongest brawler in that row.</p>
          </div>

          <div style="display:flex; gap:0.65rem; flex-wrap:wrap;">
            <button class="button" type="button" data-save-image>Save Image</button>
            <button class="button" type="button" data-reset>Reset Board</button>
          </div>
        </section>

        <section class="board" aria-label="Interactive brawler meta builder">
          {initialBoard.map((tier) => (
            <div class="tier-row">
              <div class="tier-label" style={`background: ${tier.color};`}>{tier.label}</div>
              <div class="tier-content" data-tier={tier.label}></div>
            </div>
          ))}
        </section>
      </main>
    </div>

    <script define:vars={{ initialBoard }}>
      const storageKey = "brawlex-meta-builder-v3";
      const knownCards = new Map(
        initialBoard.flatMap((tier) => tier.cards.map((card) => [card.name, { ...card }]))
      );
      const boardElement = document.querySelector(".board");
      const saveImageButton = document.querySelector("[data-save-image]");
      let activeCardName = null;
      let activeCardElement = null;
      let placeholder = null;

      function cloneBoard() {
        return initialBoard.map((tier) => ({
          label: tier.label,
          color: tier.color,
          cards: tier.cards.map((card) => ({ ...card }))
        }));
      }

      function sanitizeBoard(candidate) {
        if (!Array.isArray(candidate) || candidate.length !== initialBoard.length) {
          return cloneBoard();
        }

        const seen = new Set();

        const next = initialBoard.map((tier, index) => {
          const sourceCards = Array.isArray(candidate[index]?.cards) ? candidate[index].cards : [];
          return {
            label: tier.label,
            color: tier.color,
            cards: sourceCards
              .map((card) => {
                const name = typeof card === "string" ? card : card?.name;
                if (!name || seen.has(name) || !knownCards.has(name)) {
                  return null;
                }
                seen.add(name);
                return { ...knownCards.get(name) };
              })
              .filter(Boolean)
          };
        });

        for (const [name, card] of knownCards.entries()) {
          if (!seen.has(name)) {
            next[next.length - 1].cards.push({ ...card });
          }
        }

        return next;
      }

      function loadBoard() {
        try {
          const raw = localStorage.getItem(storageKey);
          return raw ? sanitizeBoard(JSON.parse(raw)) : cloneBoard();
        } catch {
          return cloneBoard();
        }
      }

      let board = loadBoard();

      function persistBoard() {
        localStorage.setItem(
          storageKey,
          JSON.stringify(
            board.map((tier) => ({
              label: tier.label,
              cards: tier.cards.map((card) => card.name)
            }))
          )
        );
      }

      function clearActiveStates() {
        document.querySelectorAll(".card").forEach((card) => {
          card.classList.remove("is-dragging", "is-target");
        });
        document.querySelectorAll(".tier-content").forEach((tier) => {
          tier.classList.remove("is-over");
        });
      }

      function removePlaceholder() {
        if (placeholder?.parentElement) {
          placeholder.parentElement.removeChild(placeholder);
        }
      }

      function ensurePlaceholder() {
        if (!placeholder) {
          placeholder = document.createElement("div");
          placeholder.className = "card-placeholder";
        }
        return placeholder;
      }

      function getPlaceholderIndex(row) {
        return Array.from(row.children).indexOf(placeholder);
      }

      function placePlaceholderNextToCard(cardElement, placeAfter) {
        const row = cardElement.parentElement;
        if (!row) {
          return;
        }

        const marker = ensurePlaceholder();
        const sibling = placeAfter ? cardElement.nextSibling : cardElement;
        if (sibling !== marker) {
          row.insertBefore(marker, sibling);
        }
      }

      function syncBoardFromDom() {
        board = initialBoard.map((tier) => {
          const row = document.querySelector(`[data-tier="${tier.label}"]`);
          const cards = row
            ? Array.from(row.querySelectorAll(":scope > .card"))
                .map((card) => card.dataset.name)
                .filter(Boolean)
                .map((name) => ({ ...knownCards.get(name) }))
            : tier.cards.map((card) => ({ ...card }));

          return {
            label: tier.label,
            color: tier.color,
            cards
          };
        });
      }

      function commitDrop(targetRow) {
        if (!activeCardElement || !targetRow || !placeholder || placeholder.parentElement !== targetRow) {
          return;
        }

        targetRow.insertBefore(activeCardElement, placeholder);
        activeCardElement.classList.remove("is-hidden", "is-dragging", "is-target");
        removePlaceholder();
        syncBoardFromDom();
        persistBoard();
      }

      function createCard(card) {
        const link = document.createElement("a");
        link.className = "card";
        link.href = card.href;
        link.draggable = true;
        link.dataset.name = card.name;
        link.style.setProperty("--portrait-scale", String(card.scale ?? 1));

        link.addEventListener("dragstart", (event) => {
          activeCardName = card.name;
          activeCardElement = link;
          link.parentElement?.insertBefore(ensurePlaceholder(), link);
          link.classList.add("is-dragging");
          window.setTimeout(() => {
            link.classList.add("is-hidden");
          }, 0);
          if (event.dataTransfer) {
            event.dataTransfer.effectAllowed = "move";
            event.dataTransfer.setData("text/plain", card.name);
          }
        });

        link.addEventListener("dragend", () => {
          if (activeCardElement) {
            activeCardElement.classList.remove("is-hidden", "is-dragging", "is-target");
          }
          removePlaceholder();
          clearActiveStates();
          activeCardName = null;
          activeCardElement = null;
        });

        link.addEventListener("dragover", (event) => {
          event.preventDefault();
          event.stopPropagation();
          const rect = link.getBoundingClientRect();
          const placeAfter = event.clientX > rect.left + rect.width / 2;
          placePlaceholderNextToCard(link, placeAfter);
          if (card.name !== activeCardName) {
            link.classList.add("is-target");
          }
          if (event.dataTransfer) {
            event.dataTransfer.dropEffect = "move";
          }
        });

        link.addEventListener("dragleave", () => {
          link.classList.remove("is-target");
        });

        link.addEventListener("drop", (event) => {
          event.preventDefault();
          event.stopPropagation();
          clearActiveStates();
          commitDrop(link.parentElement);
        });

        const thumb = document.createElement("div");
        thumb.className = "thumb";

        const image = document.createElement("img");
        image.src = card.portrait;
        image.alt = `${card.name} avatar`;
        image.loading = "lazy";

        const label = document.createElement("div");
        label.className = "name";
        label.textContent = card.name;

        thumb.append(image);
        link.append(thumb, label);
        return link;
      }

      function renderBoard() {
        board.forEach((tier) => {
          const row = document.querySelector(`[data-tier="${tier.label}"]`);
          if (!row) {
            return;
          }

          row.innerHTML = "";
          row.ondragover = (event) => {
            event.preventDefault();
            row.classList.add("is-over");
            if (event.target === row) {
              row.append(ensurePlaceholder());
            }
            if (event.dataTransfer) {
              event.dataTransfer.dropEffect = "move";
            }
          };

          row.ondragleave = (event) => {
            if (event.currentTarget === row) {
              row.classList.remove("is-over");
            }
          };

          row.ondrop = (event) => {
            event.preventDefault();
            row.classList.remove("is-over");
            clearActiveStates();
            commitDrop(row);
          };

          tier.cards.forEach((card) => {
            row.append(createCard(card));
          });
        });
      }

      document.querySelector("[data-reset]")?.addEventListener("click", () => {
        board = cloneBoard();
        persistBoard();
        renderBoard();
      });

      saveImageButton?.addEventListener("click", async () => {
        if (!boardElement) {
          return;
        }

        saveImageButton.disabled = true;
        const originalText = saveImageButton.textContent;
        saveImageButton.textContent = "Saving...";

        try {
          const { default: html2canvas } = await import("https://esm.sh/html2canvas@1.4.1");
          const canvas = await html2canvas(boardElement, {
            backgroundColor: "#23293a",
            useCORS: true,
            scale: Math.min(window.devicePixelRatio || 1, 2)
          });

          const link = document.createElement("a");
          link.href = canvas.toDataURL("image/png");
          link.download = "brawlex-meta-tier-list.png";
          link.click();
        } finally {
          saveImageButton.disabled = false;
          saveImageButton.textContent = originalText;
        }
      });

      renderBoard();
    </script>
  </body>
</html>
