---
import MainNav from "../components/MainNav.astro";
import { brawlerOrder, slugifyBrawler } from "../data/brawlers";

const title = "Brawlex | Meta Builder";
const brawlerAssetModules = import.meta.glob("../assets/brawlers/*.avif", {
  eager: true,
  import: "default"
});

type AssetModule = {
  src: string;
};

type TierEntry = {
  label: string;
  color: string;
  brawlers: string[];
};

const orderedAssets = Object.entries(brawlerAssetModules)
  .sort(([left], [right]) => {
    const leftId = Number(left.match(/(\d+)\.avif$/)?.[1] ?? 0);
    const rightId = Number(right.match(/(\d+)\.avif$/)?.[1] ?? 0);
    return leftId - rightId;
  })
  .map(([, asset]) => (asset as AssetModule).src);

const portraitByName = new Map(brawlerOrder.map((name, index) => [name, orderedAssets[index] ?? ""]));
const portraitScaleByName: Record<string, number> = {
  Finx: 0.82,
  Kaze: 0.82,
  Mina: 0.84,
  Ziggy: 0.84,
  Gigi: 0.84,
  Glowbert: 0.84,
  Sirius: 0.82,
  Najia: 0.84
};

const tiers: TierEntry[] = [
  {
    label: "S",
    color: "#f87171",
    brawlers: ["Bibi", "Sirius", "Rico", "Crow", "Mortis", "Spike", "Bull", "Leon"]
