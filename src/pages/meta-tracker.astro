---
import MainNav from "../components/MainNav.astro";
import { brawlerOrder, slugifyBrawler } from "../data/brawlers";

const title = "Brawlex | Meta Tracker";
const brawlerAssetModules = import.meta.glob("../assets/brawlers/*.png", {
  eager: true,
  import: "default"
});

type AssetModule = {
  src: string;
};

const orderedAssets = Object.entries(brawlerAssetModules)
  .sort(([left], [right]) => {
    const leftId = Number(left.match(/(\d+)\.png$/)?.[1] ?? 0);
    const rightId = Number(right.match(/(\d+)\.png$/)?.[1] ?? 0);
    return leftId - rightId;
  })
  .map(([, asset]) => (asset as AssetModule).src);

const portraitByName = new Map(brawlerOrder.map((name, index) => [name, orderedAssets[index] ?? null]));

const tiers = [
  {
    label: "S",
    color: "#f87171",
    brawlers: ["Bibi", "Sirius", "Rico", "Crow", "Mortis", "Spike", "Bull", "Leon"]
