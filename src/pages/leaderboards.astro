---
import MainNav from "../components/MainNav.astro";
import { brawlerOrder } from "../data/brawlers";
import topPlayersData from "../data/top_players.json";

const title = "Brawlex | Leaderboards";
const brawlerAssetModules = import.meta.glob("../assets/brawlers/*.avif", {
  eager: true,
  import: "default"
});

type AssetModule = {
  src: string;
};

const orderedAssets = Object.entries(brawlerAssetModules)
  .sort(([left], [right]) => {
    const leftId = Number(left.match(/(\d+)\.avif$/)?.[1] ?? 0);
    const rightId = Number(right.match(/(\d+)\.avif$/)?.[1] ?? 0);
    return leftId - rightId;
  })
  .map(([, asset]) => (asset as AssetModule).src);

const avatarByName = new Map(brawlerOrder.map((name, index) => [name, orderedAssets[index] ?? null]));

type TopPlayer = {
  tag: string;
  name: string;
  nameColor: string;
  icon: { id: number };
  trophies: number;
  rank: number;
  club?: { name?: string };
};

function formatTrophies(value: number) {
  if (value >= 1000) {
    return `${(value / 1000).toFixed(1).replace(/\.0$/, "")}K`;
  }

  return String(value);
}

function normalizeNameColor(value: string) {
  return "#" + value.replace(/^0x/i, "").slice(-6);
}

const players = (topPlayersData.items as TopPlayer[]).map((player) => ({
  rank: player.rank,
  name: player.name,
  nameColor: normalizeNameColor(player.nameColor),
  tag: player.tag,
  trophies: formatTrophies(player.trophies),
  trophiesRaw: player.trophies,
  club: player.club?.name ?? "No Club",
  avatar: orderedAssets[player.icon.id % orderedAssets.length] ?? null
}));

const playerCount = players.length;
const topTrophies = players[0]?.trophies ?? "0";

function getRowTone(rank: number) {
  if (rank === 1) return "gold";
  if (rank === 2) return "silver";
  if (rank === 3) return "bronze";
  return "default";
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Lilita+One&display=swap");

      :root {
        color-scheme: dark;
        --bg: #0b0d12;
        --panel: #141720;
        --panel-soft: #1a1f2a;
        --line: rgba(255, 255, 255, 0.07);
        --text: #f2f5fb;
        --muted: #8e97aa;
        --gold: #ffca28;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Lilita One", "Trebuchet MS", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(245, 158, 11, 0.12), transparent 28%),
          linear-gradient(180deg, #0b0d12, #0d1016 55%, #0b0d12);
      }

      .page-shell { min-height: 100vh; padding: 1rem 1rem 2.5rem; }
      header { padding-top: 0.5rem; }
      main { width: min(1120px, calc(100vw - 2rem)); margin: 1.25rem auto 0; }

      .hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.45rem 1.5rem;
        border: 1px solid rgba(255, 196, 66, 0.18);
        border-radius: 18px;
        background: linear-gradient(90deg, rgba(255, 178, 34, 0.26), rgba(255, 178, 34, 0.08) 36%, rgba(255, 255, 255, 0.02));
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.28);
      }

      .hero-main {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .hero-icon {
        width: 64px;
        height: 64px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: rgba(255, 196, 66, 0.16);
        font-size: 2rem;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 0.95;
      }

      .hero p {
        margin: 0.35rem 0 0;
        color: #d7dde9;
        font-size: 1.05rem;
      }

      .hero-stats {
        display: flex;
        gap: 0.85rem;
      }

      .hero-stat {
        min-width: 116px;
        padding: 0.85rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 14px;
        background: rgba(11, 13, 18, 0.46);
      }

      .hero-stat strong {
        display: block;
        font-size: 1.2rem;
      }

      .hero-stat span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .controls {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1.25rem;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--panel);
      }

      .tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .tab {
        padding: 0.8rem 1.1rem;
        border: 1px solid transparent;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.04);
        color: #cfd7e6;
        font-weight: 700;
      }

      .tab.active {
        border-color: rgba(255, 196, 66, 0.45);
        background: rgba(255, 196, 66, 0.14);
        color: #ffcf4d;
      }

      .select-shell {
        min-width: 220px;
        padding: 0.85rem 1rem;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.03);
        color: #e8edf7;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .rows {
        margin-top: 1.25rem;
        display: grid;
        gap: 0.65rem;
      }

      .row {
        display: grid;
        grid-template-columns: 56px 54px minmax(0, 1.2fr) 150px 140px 28px;
        align-items: center;
        gap: 1rem;
        padding: 0.95rem 1rem;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
      }

      .row.gold {
        border-color: rgba(255, 196, 66, 0.5);
        background: linear-gradient(90deg, rgba(255, 178, 34, 0.28), rgba(255, 178, 34, 0.06) 55%, rgba(255,255,255,0.01));
      }

      .row.silver {
        border-color: rgba(209, 213, 219, 0.45);
        background: linear-gradient(90deg, rgba(209, 213, 219, 0.25), rgba(209, 213, 219, 0.05) 55%, rgba(255,255,255,0.01));
      }

      .row.bronze {
        border-color: rgba(205, 127, 50, 0.45);
        background: linear-gradient(90deg, rgba(205, 127, 50, 0.28), rgba(205, 127, 50, 0.06) 55%, rgba(255,255,255,0.01));
      }

      .rank {
        width: 38px;
        height: 38px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        font-weight: 900;
        font-size: 1.15rem;
        background: rgba(255, 255, 255, 0.12);
        color: #0b0d12;
      }

      .gold .rank { background: #facc15; }
      .silver .rank { background: #d1d5db; }
      .bronze .rank { background: #f59e0b; }
      .default .rank {
        width: auto;
        height: auto;
        background: transparent;
        color: #7e8797;
        border-radius: 0;
      }

      .avatar {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        overflow: hidden;
        border: 2px solid #05070c;
        background: #0d1119;
      }

      .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .identity strong {
        display: inline-block;
        font-size: 1.1rem;
      }

      .identity .country {
        margin-left: 0.35rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .identity .tag {
        margin-top: 0.2rem;
        color: #6f788c;
        font-size: 0.88rem;
      }

      .trophies {
        justify-self: end;
        color: var(--gold);
        font-weight: 900;
        font-size: 1.05rem;
      }

      .club {
        justify-self: end;
        color: #d946ef;
        font-size: 0.96rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .chevron {
        justify-self: end;
        color: #7c8497;
        font-size: 1.8rem;
        line-height: 1;
      }

      @media (max-width: 900px) {
        .hero, .controls {
          flex-direction: column;
          align-items: stretch;
        }

        .hero-stats {
          width: 100%;
        }

        .hero-stat {
          flex: 1;
        }

        .row {
          grid-template-columns: 48px 48px minmax(0, 1fr);
          gap: 0.85rem;
        }

        .trophies,
        .club,
        .chevron {
          grid-column: 3;
          justify-self: start;
        }

        .club {
          margin-top: -0.15rem;
        }
      }

      @media (max-width: 640px) {
        .page-shell { padding-inline: 0.75rem; }
        main { width: calc(100vw - 1.5rem); }
        .hero {
          padding: 1rem;
        }
        .hero-main {
          align-items: flex-start;
        }
        .hero-icon {
          width: 52px;
          height: 52px;
          font-size: 1.6rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header>
        <MainNav currentPath="/leaderboards" />
      </header>

      <main>
        <section class="hero">
          <div class="hero-main">
            <div class="hero-icon">🏆</div>
            <div>
              <h1>Player Rankings</h1>
              <p>Global · {playerCount} players</p>
            </div>
          </div>

          <div class="hero-stats">
            <div class="hero-stat">
              <strong>{playerCount}</strong>
              <span>Players</span>
            </div>
            <div class="hero-stat">
              <strong style="color:#ffcf4d;">{topTrophies}</strong>
              <span>Top Trophies</span>
            </div>
          </div>
        </section>

        <section class="controls">
          <div class="tabs">
            <div class="tab active">Players</div>
            <div class="tab">Clubs</div>
            <div class="tab">Brawlers</div>
          </div>

          <div class="select-shell">
            <span>Global</span>
            <span>⌄</span>
          </div>
        </section>

        <section class="rows" aria-label="Player leaderboard from API data">
          {players.map((player) => (
            <article class:list={["row", getRowTone(player.rank)]}>
              <div class="rank">{player.rank <= 3 ? player.rank : "#" + player.rank}</div>
              <div class="avatar">
                <img src={player.avatar ?? ""} alt={player.name + " avatar"} loading="lazy" />
              </div>
              <div class="identity">
                <div>
                  <strong style={`color: ${player.nameColor};`}>{player.name}</strong>
                  <span class="country">Global</span>
                </div>
                <div class="tag">{player.tag}</div>
              </div>
              <div class="trophies">🏆 {player.trophies}</div>
              <div class="club">{player.club}</div>
              <div class="chevron">›</div>
            </article>
          ))}
        </section>
      </main>
    </div>
  </body>
</html>
